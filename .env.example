# Copy to client/.env and fill in. client/.env is gitignored (keeps your folder id out of the
# public Pages repo). VITE_* vars are read by Vite at build time and inlined into the bundle.

# The Google Drive folder id of YOUR JarvisV2/ folder (from the folder URL:
# https://drive.google.com/drive/folders/<THIS_ID>). The app discovers all files inside it by
# name and bootstraps/migrates the store on first run. Falls back to DEFAULT_FOLDER_ID in
# client/src/lib/driveClient.js if unset.
VITE_JARVIS_FOLDER_ID=your_drive_folder_id_here

# Build target: 'local' (laptop, serves at /, shows agent triggers) or 'pages' (GitHub Pages,
# served under the subpath, no agent triggers). Defaults to 'local' when unset.
# VITE_BUILD_TARGET=local
