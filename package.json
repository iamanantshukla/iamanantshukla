{
  "name": "shooting-log-client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "npm run build:local && npm run build:pages",
    "build:local": "VITE_BUILD_TARGET=local node ./node_modules/vite/bin/vite.js build",
    "build:pages": "VITE_BUILD_TARGET=pages node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "preview:pages": "VITE_BUILD_TARGET=pages node ./node_modules/vite/bin/vite.js build && vite preview --base /iamanantshukla/",
    "test": "node ./node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
